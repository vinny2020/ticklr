    "warm.category.milestones.prompt" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ضع تذكيرًا لما يهمّ أكثر."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nastav si připomenutí na to, na čem nejvíc záleží."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stell eine Erinnerung für das ein, was am meisten zählt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Όρισε μια υπενθύμιση για ό,τι σου είναι σημαντικότερο."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set a reminder for what matters most."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crea un recordatorio para lo que más importa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Programme un rappel pour ce qui compte le plus."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "קבע תזכורת לדבר החשוב באמת."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जो सबसे ज़रूरी है, उसके लिए एक रिमाइंडर सेट करें।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Állíts be emlékeztetőt arra, ami a legfontosabb."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imposta un promemoria per ciò che conta di più."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "いちばん大切なことに、リマインダーを。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "가장 소중한 일에 알림을 설정해 보세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zet een herinnering voor wat het meest telt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ustaw przypomnienie o tym, co najważniejsze."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Define um lembrete para aquilo que mais importa."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pune un memento pentru ce contează cel mai mult."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Создай напоминание о самом важном."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sätt en påminnelse för det som betyder mest."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جو سب سے اہم ہے، اُس کے لیے ریمائنڈر سیٹ کریں۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为最重要的事，设个提醒吧。"
          }
        }
      }
    },
