    "warm.category.milestones.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا تفوّت أعياد الميلاد والذكرى السنوية والمحطّات الهادئة التي تهمّ."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Už nikdy nepropásni narozeniny, výročí ani tiché milníky, na kterých záleží."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verpasse nie wieder Geburtstage, Jubiläen und stille Meilensteine, die zählen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μη χάνεις ποτέ γενέθλια, επετείους και τα σιωπηλά ορόσημα που μετρούν."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Never miss the birthdays, anniversaries, and quiet milestones that count."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nunca pierdas de vista los cumpleaños, aniversarios y pequeños hitos que cuentan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ne rate plus jamais les anniversaires et les petites étapes qui comptent."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "אל תפספס יום הולדת, יום נישואין או אבן דרך שקטה שחשובה לך."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जन्मदिन, सालगिरह और छोटे-छोटे अहम पल — कोई न छूटे।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soha többé ne hagyj ki egy születésnapot, évfordulót vagy csendes mérföldkövet."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non perdere più compleanni, anniversari e piccole tappe che contano."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "誕生日、記念日、ささやかな節目 — どれも見逃さないように。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "생일, 기념일, 그리고 조용히 빛나는 순간들을 절대 놓치지 마세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mis nooit meer verjaardagen, jubilea en stille mijlpalen die ertoe doen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nigdy nie przegap urodzin, rocznic i cichych chwil, które naprawdę się liczą."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nunca mais percas aniversários, datas importantes e pequenos marcos que contam."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nu mai rata zilele de naștere, aniversările și reperele tăcute care contează."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не пропускай дни рождения, годовщины и тихие вехи, которые важны."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Missa aldrig födelsedagar, jubileum och de tysta milstolpar som betyder något."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سالگرہ، یومِ تجدیدِ عہد اور خاموش لمحات — کوئی اہم بات کبھی فوت نہ ہو۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不再错过生日、纪念日，以及那些悄悄重要的瞬间。"
          }
        }
      }
    },
