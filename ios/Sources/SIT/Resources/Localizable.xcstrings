    "onboarding.subtitle" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "شبكتك الشخصية، بخصوصية تامّة.\nبلا سحابة. بلا رسم اجتماعي. الأشخاص المهمون لك فقط."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vaše osobní síť, soukromě.\nŽádný cloud. Žádná sociální síť. Jen vaši lidé."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein persönliches Netzwerk, privat.\nKeine Cloud. Kein soziales Netzwerk. Nur deine Leute."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το προσωπικό σας δίκτυο, ιδιωτικά.\nΧωρίς cloud. Χωρίς κοινωνικό γράφημα. Μόνο οι άνθρωποί σας."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your personal network, privately.\nNo cloud. No social graph. Just your people."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu red personal, en privado.\nSin nube. Sin red social. Solo tu gente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre réseau personnel, en privé.\nSans cloud. Sans réseau social. Juste vos contacts."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הרשת האישית שלך, בפרטיות.\nבלי ענן. בלי גרף חברתי. רק האנשים שלך."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपका निजी नेटवर्क, गोपनीय रूप से।\nकोई क्लाउड नहीं। कोई सोशल ग्राफ नहीं। बस आपके लोग।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A személyes hálózatod, privát módon.\nNincs felhő. Nincs közösségi háló. Csak a te embereid."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tua rete personale, in privato.\nNessun cloud. Nessun social. Solo le tue persone."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プライベートな個人ネットワーク。\nクラウドなし。ソーシャルグラフなし。あなたの人だけ。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "개인 네트워크를 비공개로 관리하세요.\n클라우드 없음. 소셜 그래프 없음. 내 사람들만."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jouw persoonlijk netwerk, privé.\nGeen cloud. Geen sociaal netwerk. Gewoon jouw mensen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twoja osobista sieć, prywatnie.\nBez chmury. Bez sieci społecznościowej. Tylko Twoi ludzie."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A sua rede pessoal, de forma privada.\nSem nuvem. Sem rede social. Apenas as suas pessoas."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rețeaua ta personală, în mod privat.\nFără cloud. Fără rețea socială. Doar oamenii tăi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваша личная сеть, конфиденциально.\nНет облака. Нет соцграфа. Только ваши люди."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ditt personliga nätverk, privat.\nIngen moln. Inget socialt nätverk. Bara ditt folk."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "آپ کا ذاتی نیٹ ورک، نجی طور پر۔\nکوئی کلاؤڈ نہیں۔ کوئی سوشل گراف نہیں۔ صرف آپ کے لوگ۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "私密管理您的个人人脉网。\n无云端。无社交图谱。只有您的人。"
          }
        }
      }
    },
