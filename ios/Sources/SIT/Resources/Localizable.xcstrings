    "warm.category.community.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "دائرتك الواسعة تُبقيك متّزنًا — فاعتنِ بها."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Širší okruh tě drží při zemi. Pečuj o něj."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein erweiterter Kreis hält dich geerdet. Pflege ihn."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ο ευρύτερος κύκλος σου σε κρατά γειωμένο. Φρόντισέ τον."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your wider circle keeps you grounded. Tend to it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu círculo más amplio te mantiene con los pies en la tierra. Cuídalo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ton cercle élargi te garde les pieds sur terre. Prends-en soin."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "המעגל הרחב שלך שומר עליך מקורקע. טפח אותו."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपका बड़ा दायरा आपको ज़मीन से जोड़े रखता है — उसकी देखभाल करें।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A tágabb köröd tart téged földön. Ápold."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La cerchia più ampia ti tiene con i piedi per terra. Coltivala."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの広い輪が、あなたを支えている。手をかけよう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "더 넓은 인연이 당신을 단단히 지탱해 줍니다. 잘 보살피세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je bredere kring houdt je geaard. Verzorg hem."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Szerszy krąg trzyma cię przy ziemi. Zadbaj o niego."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O teu círculo mais alargado mantém-te com os pés na terra. Cuida dele."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cercul mai larg te ține cu picioarele pe pământ. Ai grijă de el."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Твой широкий круг помогает тебе оставаться собой. Заботься о нём."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din vidare krets håller dig jordad. Vårda den."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "آپ کا وسیع تر حلقہ آپ کو زمین سے جوڑے رکھتا ہے — اِس کی دیکھ بھال کیجیے۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "更广的圈子让你脚踏实地，记得用心维系。"
          }
        }
      }
    },
