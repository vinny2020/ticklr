    "warm.onboarding.footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خصوصيّة Ticklr بطبيعتها. جهات اتصالك وملاحظاتك لا تغادر هذا الجهاز أبدًا."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr je soukromý už od návrhu. Tvoje kontakty a poznámky toto zařízení nikdy neopustí."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr ist von Grund auf privat. Deine Kontakte und Notizen verlassen dieses Gerät nie."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το Ticklr είναι ιδιωτικό από σχεδιασμό. Επαφές και σημειώσεις δεν φεύγουν από τη συσκευή."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr is private by design. Your contacts and notes never leave this device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr es privada por diseño. Tus contactos y notas nunca salen de este dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr est privée par conception. Tes contacts et tes notes ne quittent jamais cet appareil."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr פרטית מתוקף עיצובה. אנשי הקשר וההערות שלך לעולם אינם עוזבים את המכשיר."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr शुरू से ही निजी है। आपके संपर्क और नोट्स इस डिवाइस से कभी नहीं जाते।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Ticklr alapból privát. A névjegyeid és jegyzeteid soha nem hagyják el az eszközt."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr è privata fin dalla progettazione. Contatti e note non lasciano mai il dispositivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr は設計上プライベート。連絡先やメモがこの端末を離れることはありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr는 처음부터 프라이빗합니다. 연락처와 메모는 절대 이 기기를 떠나지 않습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr is privé van nature. Je contacten en notities verlaten dit apparaat nooit."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr jest prywatny z założenia. Twoje kontakty i notatki nigdy nie opuszczają tego urządzenia."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Ticklr é privado por natureza. Os teus contactos e notas nunca saem deste dispositivo."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr e privat din construcție. Contactele și notițele nu părăsesc acest dispozitiv."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr приватен по умолчанию. Твои контакты и заметки никогда не покидают это устройство."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr är privat från grunden. Dina kontakter och anteckningar lämnar aldrig enheten."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr بنیاد ہی سے نجی ہے۔ آپ کے روابط اور نوٹس کبھی اس آلے سے باہر نہیں جاتے۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ticklr 自始隐私。你的联系人和笔记不会离开这台设备。"
          }
        }
      }
    },
    "warm.onboarding.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "طريقة لطيفة لإبقاء من يهمّك قريبًا منك."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Šetrnější způsob, jak držet blízko ty, na kterých záleží."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine sanftere Art, die Menschen, die zählen, nah zu halten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ένας πιο τρυφερός τρόπος να κρατάς κοντά τους ανθρώπους που σου αξίζουν."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A gentler way to keep the people who matter close."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una forma amable de mantener cerca a quien importa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une façon plus douce de garder près de soi ceux qui comptent."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "דרך עדינה יותר לשמור קרוב את האנשים החשובים."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जो लोग मायने रखते हैं, उन्हें क़रीब रखने का एक कोमल तरीक़ा।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gyengédebb módja annak, hogy a fontos emberek közel maradjanak."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un modo più gentile per tenere vicine le persone che contano."
          }
        },
        "ja" : {
