    "tickleEdit.noGroups.description": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Groups let you tickle everyone on a team or in a circle at once."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los grupos te permiten recordar a todos en un equipo o círculo a la vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les groupes vous permettent de rappeler tout le monde dans une équipe ou un cercle en même temps."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gruppen ermöglichen es dir, alle in einem Team oder Kreis gleichzeitig zu erinnern."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I gruppi ti permettono di ricordare a tutti in un team o in un cerchio allo stesso tempo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Groepen stellen je in staat iedereen in een team of cirkel tegelijk te herinneren."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι ομάδες σας επιτρέπουν να θυμίσετε σε όλους σε μια ομάδα ή σε έναν κύκλο ταυτόχρονα."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Grupy pozwalają przypomnieć wszystkim w zespole lub kręgu jednocześnie."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Grupurile vă permit să amintiți tuturor dintr-o echipă sau dintr-un cerc deodată."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A csoportok lehetővé teszik, hogy egyszerre mindenkinek emlékeztess egy csapaton belül."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os grupos permitem-lhe lembrar a todos numa equipa ou círculo de uma vez."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Grupper låter dig påminna alla i ett team eller en cirkel på en gång."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Skupiny vám umožňují připomenout všem v týmu nebo kruhu najednou."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Группы позволяют напоминать всем в команде или круге сразу."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "群组让您可以同时提醒团队或圈子中的所有人。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "グループを使うと、チームやサークル全員に一度にリマインドできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
