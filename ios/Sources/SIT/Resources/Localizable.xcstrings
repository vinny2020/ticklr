    "warm.category.friends.prompt" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تواصل مع صديق لم تتحدّث معه منذ فترة."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ozvi se kamarádovi, se kterým jsi dlouho nemluvil."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melde dich wieder bei einem Freund, mit dem du lange nicht geredet hast."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Έλα ξανά σε επαφή με έναν φίλο που έχεις καιρό να μιλήσεις."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reconnect with a friend you haven’t talked to in a while."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vuelve a conectar con un amigo con quien no hablas desde hace tiempo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reprends contact avec un ami que tu n'as pas vu depuis longtemps."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "חדש קשר עם חבר שלא דיברת איתו כבר זמן."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी पुराने दोस्त से दोबारा जुड़ें।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vedd fel újra a kapcsolatot egy baráttal, akivel régen beszéltél."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riconnettiti con un amico con cui non parli da un po'."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "しばらく話していない友人と、もう一度つながろう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "오랫동안 연락하지 못한 친구에게 다시 연락해 보세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neem opnieuw contact op met een vriend(in) die je al een tijd niet sprak."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odezwij się do znajomego, z którym dawno nie rozmawiałeś."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Volta a falar com um amigo com quem não conversas há tempos."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reia legătura cu un prieten cu care n-ai mai vorbit de mult."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Свяжись с другом, с которым давно не общался."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ta kontakt igen med en vän du inte pratat med på länge."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "کسی پرانے دوست سے دوبارہ رابطہ کیجیے۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "联系一位许久未谈的朋友。"
          }
        }
      }
    },
    "warm.category.friends.promptShort" : {
