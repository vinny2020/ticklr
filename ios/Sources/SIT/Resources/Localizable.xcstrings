    "settings.footer.notificationsDenied" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم رفض إذن الإشعارات. فعِّله في إعدادات iOS لتلقّي تذكيرات Tickle."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přístup k oznámením byl odepřen. Povolte jej v nastavení iOS pro příjem připomenutí."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Zugriff auf Benachrichtigungen wurde verweigert. Aktiviere es in den iOS-Einstellungen, um Erinnerungen zu erhalten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η πρόσβαση στις ειδοποιήσεις απορρίφθηκε. Ενεργοποιήστε την στις Ρυθμίσεις iOS για να λαμβάνετε υπενθυμίσεις."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notification access was denied. Enable it in iOS Settings to receive tickle reminders."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El acceso a notificaciones fue denegado. Actívalo en Ajustes de iOS para recibir recordatorios."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accès aux notifications a été refusé. Activez-le dans les réglages iOS pour recevoir des rappels."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הגישה להתראות נדחתה. הפעילו אותה בהגדרות iOS כדי לקבל תזכורות."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अधिसूचना पहुंच अस्वीकृत। रिमाइंडर प्राप्त करने के लिए iOS सेटिंग में सक्षम करें।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az értesítési hozzáférés megtagadva. Engedélyezd az iOS Beállításokban az emlékeztetők fogadásához."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accesso alle notifiche è stato negato. Abilitalo nelle impostazioni iOS per ricevere promemoria."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通知アクセスが拒否されました。リマインダーを受け取るにはiOS設定で有効にしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "알림 접근이 거부되었습니다. 알림을 받으려면 iOS 설정에서 활성화하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toegang tot meldingen is geweigerd. Schakel het in bij iOS-instellingen om herinneringen te ontvangen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dostęp do powiadomień został odrzucony. Włącz go w ustawieniach iOS, aby otrzymywać przypomnienia."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O acesso a notificações foi negado. Ative-o nas definições do iOS para receber lembretes."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accesul la notificări a fost refuzat. Activați-l în Setările iOS pentru a primi memento-uri."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ к уведомлениям запрещён. Включите его в настройках iOS для получения напоминаний."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Åtkomst till aviseringar nekades. Aktivera det i iOS-inställningar för att ta emot påminnelser."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نوٹیفکیشن رسائی مسترد کر دی گئی۔ یاددہانیاں حاصل کرنے کے لیے اسے iOS ترتیبات میں فعال کریں۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通知访问被拒绝。请在iOS设置中启用以接收提醒。"
          }
        }
      }
    },
