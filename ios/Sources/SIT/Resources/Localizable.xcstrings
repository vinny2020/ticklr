    "settings.footer.notificationsDenied": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Notification access was denied. Enable it in iOS Settings to receive tickle reminders."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso a notificaciones fue denegado. Actívalo en Ajustes de iOS para recibir recordatorios."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès aux notifications a été refusé. Activez-le dans les réglages iOS pour recevoir des rappels."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Zugriff auf Benachrichtigungen wurde verweigert. Aktiviere es in den iOS-Einstellungen, um Erinnerungen zu erhalten."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accesso alle notifiche è stato negato. Abilitalo nelle impostazioni iOS per ricevere promemoria."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Toegang tot meldingen is geweigerd. Schakel het in bij iOS-instellingen om herinneringen te ontvangen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η πρόσβαση στις ειδοποιήσεις απορρίφθηκε. Ενεργοποιήστε την στις Ρυθμίσεις iOS για να λαμβάνετε υπενθυμίσεις."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostęp do powiadomień został odrzucony. Włącz go w ustawieniach iOS, aby otrzymywać przypomnienia."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesul la notificări a fost refuzat. Activați-l în Setările iOS pentru a primi memento-uri."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az értesítési hozzáférés megtagadva. Engedélyezd az iOS Beállításokban az emlékeztetők fogadásához."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso a notificações foi negado. Ative-o nas definições do iOS para receber lembretes."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Åtkomst till aviseringar nekades. Aktivera det i iOS-inställningar för att ta emot påminnelser."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přístup k oznámením byl odepřen. Povolte jej v nastavení iOS pro příjem připomenutí."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступ к уведомлениям запрещён. Включите его в настройках iOS для получения напоминаний."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通知访问被拒绝。请在iOS设置中启用以接收提醒。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通知アクセスが拒否されました。リマインダーを受け取るにはiOS設定で有効にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "알림 접근이 거부되었습니다. 알림을 받으려면 iOS 설정에서 활성화하세요."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अधिसूचना पहुंच अस्वीकृत। रिमाइंडर प्राप्त करने के लिए iOS सेटिंग में सक्षम करें।"
          }
        }
      }
    },
    "settings.footer.notificationsOff": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tickle notifications are off. You can still view due reminders in the app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las notificaciones de Tickle están desactivadas. Aún puedes ver los recordatorios en la app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les notifications Tickle sont désactivées. Vous pouvez toujours voir les rappels dans l'app."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tickle-Benachrichtigungen sind deaktiviert. Du kannst fällige Erinnerungen noch in der App ansehen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le notifiche Tickle sono disattivate. Puoi ancora vedere i promemoria nell'app."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tickle-meldingen zijn uitgeschakeld. Je kunt nog steeds openstaande herinneringen in de app zien."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι ειδοποιήσεις Tickle είναι απενεργοποιημένες. Μπορείτε ακόμα να δείτε τις υπενθυμίσεις στην εφαρμογή."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Powiadomienia Tickle są wyłączone. Nadal możesz przeglądać zaległe przypomnienia w aplikacji."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Notificările Tickle sunt dezactivate. Poți vedea în continuare memento-urile în aplicație."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Tickle értesítések ki vannak kapcsolva. Az esedékes emlékeztetőket az alkalmazásban még mindig megtekintheted."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As notificações Tickle estão desativadas. Ainda pode ver lembretes na app."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tickle-aviseringar är avstängda. Du kan fortfarande se påminnelser i appen."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tickle oznámení jsou vypnuta. Stále můžete zobrazit připomenutí v aplikaci."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Уведомления tickle отключены. Вы можете видеть просроченные напоминания в приложении."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Tickle通知已关闭。您仍可在应用中查看到期提醒。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tickle通知がオフです。アプリで期限切れのリマインダーを確認できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Tickle 알림이 꺼져 있습니다. 앱에서 기한이 지난 알림을 확인할 수 있습니다."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tickle अधिसूचनाएं बंद हैं। आप ऐप में देय रिमाइंडर देख सकते हैं।"
          }
        }
      }
    },
