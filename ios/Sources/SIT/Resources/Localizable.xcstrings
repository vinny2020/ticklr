    "warm.category.work.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انمُ مع الأشخاص الذين تبني معهم — فصلًا بعد فصل."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Růsti spolu s lidmi, se kterými budujete — čtvrtletí po čtvrtletí."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wachse mit den Menschen, mit denen du etwas aufbaust — Quartal für Quartal."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Εξελίσσου μαζί με τους ανθρώπους με τους οποίους χτίζεις — τρίμηνο με τρίμηνο."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grow alongside the people you build with — quarter by quarter."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crece junto a las personas con las que construyes — trimestre a trimestre."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Évolue aux côtés de celles et ceux avec qui tu construis — trimestre après trimestre."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "צמח לצד האנשים שאיתם אתה בונה — רבעון אחר רבעון."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जिनके साथ आप कुछ बनाते हैं, उनके साथ हर तिमाही बढ़ते रहें।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Növekedj együtt azokkal, akikkel építesz — negyedévről negyedévre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cresci insieme a chi costruisce con te — trimestre dopo trimestre."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一緒に積み上げてきた人たちと、四半期ごとに育っていく。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "함께 만들어가는 사람들과 분기마다 성장해 보세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Groei mee met de mensen met wie je bouwt — kwartaal na kwartaal."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rośnij razem z ludźmi, z którymi tworzysz — kwartał po kwartale."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cresce ao lado das pessoas com quem constróis — trimestre após trimestre."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Crește alături de oamenii cu care construiești — trimestru cu trimestru."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Расти вместе с теми, с кем строишь, — квартал за кварталом."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Väx tillsammans med människorna du bygger med — kvartal för kvartal."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جن کے ساتھ آپ کچھ بناتے ہیں، اُن کے ساتھ ہر سہ ماہی میں بڑھتے رہیں۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "与并肩前行的人一起成长 — 一个季度，又一个季度。"
          }
        }
      }
    },
