    "warm.category.friends.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اعتنِ بالروابط التي لا يمحوها الزمن ولا تُبعدها المسافة."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pečuj o vazby, které čas ani vzdálenost nedokážou oslabit."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pflege die Verbindungen, die Zeit und Distanz nicht verblassen lassen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Φρόντισε τους δεσμούς που ο χρόνος και η απόσταση δεν ξεθωριάζουν."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nurture the bonds that time and distance can’t fade."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuida los lazos que el tiempo y la distancia no pueden borrar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entretiens les liens que ni le temps ni la distance ne peuvent effacer."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "טפח את הקשרים שזמן ומרחק אינם מעמעמים."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जिन रिश्तों को समय और दूरी फीका नहीं कर सकती — उन्हें सींचते रहें।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ápold azokat a kötelékeket, amelyeket idő és távolság sem koptat el."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coltiva i legami che il tempo e la distanza non possono affievolire."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "時間や距離が薄められない絆を、丁寧に育てよう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "시간과 거리에도 흐려지지 않는 인연을 가꾸어 보세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Koester de banden die tijd en afstand niet kunnen vervagen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pielęgnuj więzi, których czas i odległość nie potrafią zatrzeć."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cultiva os laços que o tempo e a distância não conseguem apagar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hrănește legăturile pe care timpul și distanța nu le pot șterge."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Береги связи, которые не стираются ни временем, ни расстоянием."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vårda banden som varken tid eller avstånd kan blekna."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اُن رشتوں کو سینچتے رہیں جنہیں وقت اور فاصلہ بھی پھیکا نہیں کر سکتا۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用心维系时间与距离都无法褪色的情谊。"
          }
        }
      }
    },
