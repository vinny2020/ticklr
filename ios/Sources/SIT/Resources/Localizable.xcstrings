    "import.footer.description": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your connections are processed locally on your device. LinkedIn usually emails your download link within 10–30 minutes.\n\nLinkedIn data gives you the who — names and companies. You'll add phone numbers manually after importing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus conexiones se procesan localmente en tu dispositivo. LinkedIn suele enviar tu enlace de descarga en 10–30 minutos.\n\nLinkedIn te da el quién — nombres y empresas. Agregarás los números de teléfono manualmente después de importar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos connexions sont traitées localement sur votre appareil. LinkedIn envoie généralement votre lien de téléchargement dans les 10–30 minutes.\n\nLinkedIn vous donne le qui — noms et entreprises. Vous ajouterez les numéros de téléphone manuellement après l'importation."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Verbindungen werden lokal auf deinem Gerät verarbeitet. LinkedIn sendet dir den Download-Link in der Regel innerhalb von 10–30 Minuten.\n\nLinkedIn liefert das Wer — Namen und Unternehmen. Telefonnummern fügst du nach dem Import manuell hinzu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le tue connessioni vengono elaborate localmente sul tuo dispositivo. LinkedIn di solito invia il link per il download entro 10–30 minuti.\n\nLinkedIn ti dà il chi — nomi e aziende. Aggiungerai i numeri di telefono manualmente dopo l'importazione."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je verbindingen worden lokaal op je apparaat verwerkt. LinkedIn stuurt je downloadlink meestal binnen 10–30 minuten.\n\nLinkedIn geeft je het wie — namen en bedrijven. Telefoonnummers voeg je na het importeren handmatig toe."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι συνδέσεις σας επεξεργάζονται τοπικά στη συσκευή σας. Το LinkedIn συνήθως στέλνει τον σύνδεσμο λήψης εντός 10–30 λεπτών.\n\nΤο LinkedIn σας δίνει το ποιος — ονόματα και εταιρείες. Θα προσθέσετε αριθμούς τηλεφώνου χειροκίνητα μετά την εισαγωγή."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoje połączenia są przetwarzane lokalnie na Twoim urządzeniu. LinkedIn zazwyczaj wysyła link do pobrania w ciągu 10–30 minut.\n\nLinkedIn daje Ci kto — imiona i firmy. Numery telefonów dodasz ręcznie po imporcie."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Conexiunile dvs. sunt procesate local pe dispozitivul dvs. LinkedIn trimite de obicei linkul de descărcare în 10–30 de minute.\n\nLinkedIn vă oferă cine — nume și companii. Veți adăuga numerele de telefon manual după import."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A kapcsolataid helyben, az eszközödön kerülnek feldolgozásra. A LinkedIn általában 10–30 percen belül elküldi a letöltési linket.\n\nA LinkedIn megadja a kit — neveket és cégeket. A telefonszámokat az importálás után manuálisan adod hozzá."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As suas ligações são processadas localmente no seu dispositivo. O LinkedIn costuma enviar o link de download em 10–30 minutos.\n\nO LinkedIn dá-lhe o quem — nomes e empresas. Adicionará os números de telefone manualmente após importar."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dina kontakter bearbetas lokalt på din enhet. LinkedIn skickar vanligtvis din nedladdningslänk inom 10–30 minuter.\n\nLinkedIn ger dig vem — namn och företag. Du lägger till telefonnummer manuellt efter import."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaše kontakty jsou zpracovávány lokálně na vašem zařízení. LinkedIn obvykle pošle odkaz ke stažení do 10–30 minut.\n\nLinkedIn vám dá kdo — jména a společnosti. Telefonní čísla přidáte ručně po importu."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваши связи обрабатываются локально на устройстве. LinkedIn обычно отправляет ссылку на загрузку в течение 10–30 минут.\n\nДанные LinkedIn дают вам «кто» — имена и компании. Вы добавите номера телефонов вручную после импорта."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的人脉在设备本地处理。LinkedIn通常在10–30分钟内发送下载链接。\n\nLinkedIn数据提供姓名和公司信息。您可以在导入后手动添加电话号码。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "つながりはデバイス上でローカルに処理されます。LinkedInは通常10〜30分以内にダウンロードリンクをメールで送信します。\n\nLinkedInデータは「誰か」を提供します — 名前と会社。インポート後に電話番号を手動で追加します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "연락처는 기기에서 로컬로 처리됩니다. LinkedIn은 보통 10~30분 내에 다운로드 링크를 이메일로 보냅니다.\n\nLinkedIn 데이터는 '누구인지'를 알려줍니다 — 이름과 회사. 가져온 후 전화번호를 수동으로 추가합니다."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके कनेक्शन आपके डिवाइस पर स्थानीय रूप से संसाधित होते हैं। LinkedIn आमतौर पर 10–30 मिनट में डाउनलोड लिंक ईमेल करता है।\n\nLinkedIn डेटा आपको 'कौन' बताता है — नाम और कंपनियां। फ़ोन नंबर आयात के बाद मैन्युअल रूप से जोड़ें।"
          }
        }
      }
    },
