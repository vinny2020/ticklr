    "warm.category.work.prompt" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اطمئنّ على زميل وعزّز رابطًا مهنيًا."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ozvi se kolegovi a posilni pracovní vztah."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melde dich bei einem Kollegen und stärke eine berufliche Beziehung."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Πάρε νέα από έναν συνεργάτη και ενίσχυσε έναν επαγγελματικό δεσμό."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Check in and strengthen a professional bond."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saluda a un colega y fortalece un vínculo profesional."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prends des nouvelles d'un collègue et renforce un lien professionnel."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "תבדוק מה שלום קולגה וחזק קשר מקצועי."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी सहकर्मी से संपर्क करें और रिश्ता मज़बूत करें।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jelentkezz egy kollégánál, és erősítsd a szakmai kapcsolatot."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Senti un collega e rafforza un legame professionale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "同僚に近況を尋ね、関係を深めよう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "동료에게 안부를 전하고 업무 관계를 더 단단히 다져 보세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stuur een collega een berichtje en versterk de band."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odezwij się do współpracownika i wzmocnij zawodową więź."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manda um olá a um colega e fortalece um laço profissional."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salută un coleg și întărește o legătură profesională."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Напиши коллеге и укрепи профессиональную связь."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hör av dig till en kollega och stärk en yrkesrelation."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "کسی ساتھی کا حال دریافت کریں اور پیشہ ورانہ رشتہ مضبوط کیجیے۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "向同事问候一句，加深职场情谊。"
          }
        }
      }
    },
