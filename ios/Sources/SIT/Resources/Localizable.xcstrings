    "warm.category.community.prompt" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خطّط لقضاء وقت مع من تحبّ."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Naplánuj společný čas s blízkými."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan Zeit mit den Menschen ein, die du liebst."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Κανόνισε χρόνο μαζί με τους ανθρώπους που αγαπάς."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan time together with the people you love."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Planifica un rato con las personas que quieres."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prévois un moment ensemble avec ceux que tu aimes."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "תכנן זמן יחד עם האנשים שיקרים לך."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने प्रियजनों के साथ समय बिताने की योजना बनाएँ।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tervezz közös időt a szeretteiddel."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pianifica del tempo insieme alle persone che ami."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "大切な人たちと過ごす時間を計画しよう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사랑하는 사람들과 함께할 시간을 계획해 보세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan tijd samen met de mensen om wie je geeft."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaplanuj wspólny czas z bliskimi."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Marca tempo com as pessoas de quem gostas."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Planifică timp împreună cu cei dragi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Запланируй встречу с близкими."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Planera tid tillsammans med dem du tycker om."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اپنے پیاروں کے ساتھ وقت گزارنے کا منصوبہ بنائیں۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "约一段和所爱之人共度的时间。"
          }
        }
      }
    },
    "warm.category.community.promptShort" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خطّط وقتًا مع دائرتك"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Čas se svým okruhem"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeit mit deinem Kreis"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Χρόνος με τον κύκλο σου"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan time with your circle"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiempo con tu gente"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du temps avec ton entourage"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "זמן יחד עם המעגל שלך"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपनों के साथ समय निकालें"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Időt a köröddel"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tempo con la tua cerchia"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "輪の人と時間を計画"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "함께할 시간 계획하기"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tijd met je kring"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spędź czas z bliskimi"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tempo com o teu círculo"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Timp cu cercul tău"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Время с близкими"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tid med din krets"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اپنوں کے ساتھ وقت"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "和身边人聚一聚"
          }
        }
      }
    },
    "warm.category.family.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الأشخاص الذين يعرفونك جيدًا يستحقّون دائمًا الاطمئنان عليهم."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lidé, kteří tě znají nejlépe, si vždy zaslouží, aby ses ozval."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Menschen, die dich am besten kennen, sind es immer wert, dass du dich meldest."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι άνθρωποι που σε ξέρουν καλύτερα αξίζουν πάντα μια κουβέντα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The people who know you best are always worth checking in on."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las personas que mejor te conocen siempre merecen saber que piensas en ellas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les personnes qui te connaissent le mieux méritent toujours qu'on prenne de leurs nouvelles."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "האנשים שמכירים אותך הכי טוב תמיד שווים שתבדוק מה שלומם."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जो आपको सबसे अच्छे से जानते हैं, उनकी ख़बर लेना हमेशा सार्थक है।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Akik a legjobban ismernek, mindig megérik, hogy rájuk gondolj."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le persone che ti conoscono meglio meritano sempre un pensiero."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたを一番よく知る人たちには、いつでも声をかける価値がある。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신을 가장 잘 아는 사람들에게는 언제나 안부를 전할 가치가 있어요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De mensen die je het beste kennen, verdienen altijd een berichtje."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osoby, które znają cię najlepiej, zawsze zasługują na chwilę uwagi."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As pessoas que te conhecem melhor merecem sempre uma mensagem."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cei care te cunosc cel mai bine merită întotdeauna un semn de viață."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Люди, которые знают тебя лучше всех, всегда заслуживают весточки."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Människorna som känner dig bäst är alltid värda ett livstecken."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جو آپ کو سب سے بہتر جانتے ہیں، اُن کی خبر گیری ہمیشہ ضروری ہے۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最懂你的人，总值得你常常问候。"
          }
        }
      }
    },
