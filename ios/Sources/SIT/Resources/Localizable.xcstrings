    "compose.alert.sendFailed.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدث خطأ ما. رسالتك لا تزال هنا — حاول إرسالها مرة أخرى."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Něco se pokazilo. Tvoje zpráva je stále tady — zkus ji poslat znovu."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Etwas ist schiefgelaufen. Deine Nachricht ist noch da – versuche es einfach noch einmal."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Κάτι πήγε στραβά. Το μήνυμά σου είναι ακόμα εδώ — δοκίμασε να το στείλεις ξανά."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Something went wrong. Your message is still here — try sending it again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Algo salió mal. Tu mensaje sigue aquí: inténtalo de nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une erreur s'est produite. Votre message est toujours là — réessayez de l'envoyer."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "משהו השתבש. ההודעה שלך עדיין כאן — אפשר לנסות לשלוח אותה שוב."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कुछ गड़बड़ हो गई। आपका संदेश अभी भी यहीं है — इसे फिर से भेजकर देखें।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hiba történt. Az üzeneted még itt van — próbáld meg újra elküldeni."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qualcosa è andato storto. Il tuo messaggio è ancora qui: riprova a inviarlo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "問題が発生しました。メッセージはまだ残っています。もう一度送信してみてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "문제가 발생했습니다. 메시지는 그대로 남아 있으니 다시 전송해 보세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er is iets misgegaan. Je bericht staat er nog — probeer het opnieuw te versturen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coś poszło nie tak. Twoja wiadomość wciąż tu jest — spróbuj wysłać ją ponownie."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Algo deu errado. Sua mensagem ainda está aqui — tente enviá-la novamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ceva nu a mers bine. Mesajul tău este încă aici — încearcă să-l trimiți din nou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Что-то пошло не так. Ваше сообщение всё ещё здесь — попробуйте отправить его ещё раз."
          }
        },
        "sv" : {
          "stringUnit" : {
