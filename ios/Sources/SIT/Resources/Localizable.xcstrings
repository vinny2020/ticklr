    "warm.category.family.prompt" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أرسل رسالة “أفكّر فيك” إلى شخص عزيز."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pošli někomu blízkému zprávu «myslím na tebe»."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schick einer wichtigen Person eine «Ich denk an dich»-Nachricht."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Στείλε ένα «σε σκέφτομαι» σε κάποιον αγαπημένο."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Send a “thinking of you” note to someone special."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Envía a alguien especial un mensaje de «pensaba en ti»."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Envoie un mot «je pense à toi» à quelqu'un qui compte."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "שלח “חושב עליך” למישהו יקר."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी ख़ास के लिए एक “याद आ रहे हो” संदेश भेजें।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Küldj egy «rád gondolok» üzenetet valakinek, aki fontos."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manda un messaggio «pensavo a te» a qualcuno di speciale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "大切なあの人に「想っているよ」のひと言を。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "소중한 사람에게 “당신 생각이 났어요”라고 전해 보세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stuur iemand die je dierbaar is een «ik denk aan je»-bericht."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wyślij komuś ważnemu wiadomość «myślę o tobie»."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Envia uma mensagem «estou a pensar em ti» a alguém especial."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trimite cuiva drag un mesaj «mă gândesc la tine»."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Отправь дорогому человеку сообщение «думаю о тебе»."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skicka ett «tänker på dig» till någon som betyder mycket."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "کسی خاص کو “آپ یاد آ رہے ہیں” کا پیغام بھیجیں۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "给在意的人发一句“想着你”。"
          }
        }
      }
    },
